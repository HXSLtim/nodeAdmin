# Core API Configuration
PORT=3001

# Database Configuration
DATABASE_URL=postgres://nodeadmin:nodeadmin@localhost:6432/nodeadmin

# PostgreSQL Timeout Configuration (P0 Fix)
PG_CONNECTION_TIMEOUT=15000      # Connection timeout in ms (default: 15000)
PG_IDLE_TIMEOUT=300000           # Idle connection timeout in ms (default: 300000 = 5min)
PG_STATEMENT_TIMEOUT=30000       # Statement timeout in ms (default: 30000)

# Redis Configuration
REDIS_URL=redis://localhost:56379
REDIS_CONNECT_TIMEOUT=10000          # Redis connection timeout in ms (default: 10000)
REDIS_COMMAND_TIMEOUT=5000           # Redis command timeout in ms (default: 5000)
REDIS_PING_INTERVAL=15000            # Redis ping interval in ms (default: 15000)
REDIS_COMMANDS_QUEUE_MAX_LENGTH=1000 # Max queued commands (default: 1000)
REDIS_MAX_RETRIES=10                 # Max reconnection retries (default: 10)

# Socket.IO Timeout Configuration (P0 Fix)
SOCKETIO_PING_INTERVAL=25000     # Ping interval in ms (default: 25000)
SOCKETIO_PING_TIMEOUT=60000      # Ping timeout in ms (default: 60000)

# Fastify Server Configuration (P1)
FASTIFY_CONNECTION_TIMEOUT=60000 # Connection timeout in ms (default: 60000)
FASTIFY_KEEP_ALIVE_TIMEOUT=65000 # Keep-alive timeout in ms (default: 65000)
FASTIFY_REQUEST_TIMEOUT=30000    # Request timeout in ms (default: 30000)
FASTIFY_BODY_LIMIT=10485760      # Max request body size in bytes (default: 10MB)
FASTIFY_MAX_PARAM_LENGTH=500     # Max URL parameter length (default: 500)

# JWT Configuration
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend Origins (comma-separated)
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

# Auth Configuration
AUTH_ENABLE_DEV_TOKEN_ISSUE=true

# Rate Limiting
WS_RATE_LIMIT_PER_SECOND=10

# Kafka Configuration (optional)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=coreApi-outbox
OUTBOX_TOPIC=im.events
OUTBOX_DLQ_TOPIC=im.events.dlq

# Outbox Publisher Configuration
OUTBOX_PUBLISHER_ENABLED=false
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_RETRY=5
OUTBOX_POLL_INTERVAL_MS=2000

# Security Headers
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP=default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ws: wss: http: https:

# OpenTelemetry Configuration
OTEL_ENABLED=false
OTEL_METRICS_PORT=9464
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=coreApi

# Logging
LOG_LEVEL=info
