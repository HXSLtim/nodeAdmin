PORT=3001
FRONTEND_ORIGINS=http://localhost:5173,http://192.168.1.100:5173
DATABASE_URL=postgres://nodeadmin_app:nodeadmin@localhost:55432/nodeadmin
REDIS_URL=redis://localhost:56379
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_ENABLE_DEV_TOKEN_ISSUE=true
LOG_LEVEL=info
WS_RATE_LIMIT_PER_SECOND=10
OUTBOX_PUBLISHER_ENABLED=false
OUTBOX_POLL_INTERVAL_MS=2000
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_RETRY=5
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=coreApi-outbox
OUTBOX_TOPIC=im.events
OUTBOX_DLQ_TOPIC=im.events.dlq
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP=default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ws: wss: http: https:
OTEL_ENABLED=false
OTEL_SERVICE_NAME=coreApi
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_METRICS_PORT=9464
