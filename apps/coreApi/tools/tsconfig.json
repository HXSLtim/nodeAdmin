{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": false,
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "../dist-tools",
    "baseUrl": "./",
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "types": ["node"],
    "esModuleInterop": true
  },
  "include": [
    "cli/**/*",
    "generator/**/*"
  ],
  "exclude": [
    "node_modules",
    "templates"
  ]
}
