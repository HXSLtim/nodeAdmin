{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const j=JSON.parse(d);const f=j.tool_response?.filePath||j.tool_input?.file_path;if(f){require('child_process').execSync('npx prettier --write --ignore-unknown \\\"'+f+'\\\"',{stdio:'inherit'})}})\" 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Formatting with Prettier..."
          }
        ]
      }
    ]
  }
}
